#  CORE CRYPTOGRAPHIC ENGINE
# ─────────────────────────────────────────────

def shift_character(char: str, shift: int, direction: int) -> str:
    """
    Shift a single alphabetic character by `shift` positions.

    direction : +1 for encryption, -1 for decryption
    Non-alpha characters pass through untouched.

    Formula  (encrypt): E(x) = (x + n) % 26
    Formula  (decrypt): D(x) = (x - n) % 26
    """
    if char.isalpha():
        base = ord('A') if char.isupper() else ord('a')
        position    = ord(char) - base          # 0-based position in alphabet
        new_position = (position + direction * shift) % 26
        return chr(new_position + base)
    return char                                 # spaces, digits, punctuation → unchanged


def caesar_encrypt(plaintext: str, shift: int) -> str:
    """Encrypt plaintext using Caesar cipher with the given shift key."""
    return "".join(shift_character(ch, shift, +1) for ch in plaintext)


def caesar_decrypt(ciphertext: str, shift: int) -> str:
    """Decrypt ciphertext using Caesar cipher with the given shift key."""
    return "".join(shift_character(ch, shift, -1) for ch in ciphertext)


def brute_force_crack(ciphertext: str) -> list[tuple[int, str]]:
    """Try all 25 possible shift values and return (shift, plaintext) pairs."""
    results = []
    for key in range(1, 26):
        attempt = caesar_decrypt(ciphertext, key)
        results.append((key, attempt))
    return results


