def show_result_box(label_a: str, value_a: str,
                    label_b: str, value_b: str,
                    key: int):
    separator()
    print(f"  {Color.DIM}Shift Key  :{Color.RESET} {Color.BOLD}{Color.MAGENTA}{key}{Color.RESET}")
    print()
    print(f"  {Color.CYAN}{label_a:<14}{Color.RESET}: {Color.WHITE}{value_a}{Color.RESET}")
    print(f"  {Color.GREEN}{label_b:<14}{Color.RESET}: {Color.BOLD}{Color.GREEN}{value_b}{Color.RESET}")
    separator()


def show_ascii_table(text: str):
    """Display character-by-character ASCII breakdown."""
    separator("─", 60, Color.DIM)
    print(f"  {Color.DIM}{'Char':<6} {'ASCII':<8} {'Binary':<12}{Color.RESET}")
    separator("─", 60, Color.DIM)
    for ch in text[:20]:            # limit to first 20 chars to keep output tidy
        ascii_val = ord(ch)
        binary    = format(ascii_val, '08b')
        print(f"  {Color.CYAN}{ch!r:<6}{Color.RESET} {Color.YELLOW}{ascii_val:<8}{Color.RESET} {Color.DIM}{binary}{Color.RESET}")
    if len(text) > 20:
        print(f"  {Color.DIM}  ... (showing first 20 characters){Color.RESET}")
    separator("─", 60, Color.DIM)


