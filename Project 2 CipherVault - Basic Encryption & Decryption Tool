def get_shift_key(prompt: str = "  Enter shift key (1-25): ") -> int:
    while True:
        try:
            value = int(input(f"{Color.YELLOW}{prompt}{Color.RESET}"))
            if 1 <= value <= 25:
                return value
            print(f"  {Color.RED}[!] Key must be between 1 and 25.{Color.RESET}")
        except ValueError:
            print(f"  {Color.RED}[!] Please enter a valid integer.{Color.RESET}")


def get_text_input(prompt: str) -> str:
    while True:
        text = input(f"{Color.YELLOW}{prompt}{Color.RESET}").strip()
        if text:
            return text
        print(f"  {Color.RED}[!] Input cannot be empty.{Color.RESET}")


