def print_strength_bar(bar_fill: int, color: str):
    filled  = "█" * (bar_fill * 4)
    empty   = "░" * ((5 - bar_fill) * 4)
    print(f"  Strength : {color}{BOLD}{filled}{RESET}{GREY}{empty}{RESET}")


def print_report(result: dict, password: str):
    color = result["color_code"]
    level = result["level"]
    score = result["score"]

    print(f"\n{BOLD}{'─' * 62}{RESET}")
    print(f"  Password : {GREY}{'*' * len(password)}{RESET}  ({result['length']} chars)")
    print_strength_bar(result["bar_fill"], color)
    print(f"  Rating   : {color}{BOLD}{level.upper()}{RESET}  (Score: {score}/5)")
    print(f"{BOLD}{'─' * 62}{RESET}")

    # Criteria checklist
    print(f"\n{BOLD}{WHITE}  Criteria Checklist:{RESET}")
    for criterion, passed in result["criteria"].items():
        icon  = f"{GREEN}✔{RESET}" if passed else f"{RED}✘{RESET}"
        label = f"{WHITE}{criterion}{RESET}" if passed else f"{GREY}{criterion}{RESET}"
        print(f"    {icon}  {label}")

    # Issues
    if result["issues"]:
        print(f"\n{BOLD}{RED}  Issues Found:{RESET}")
        for issue in result["issues"]:
            print(f"    {RED}▶{RESET}  {issue}")

    # Tips
    if result["tips"]:
        print(f"\n{BOLD}{YELLOW}  Improvement Tips:{RESET}")
        for tip in result["tips"]:
            print(f"    {YELLOW}→{RESET}  {tip}")

    print(f"\n{BOLD}{'─' * 62}{RESET}\n")


# ─────────────────────────────────────────────────
#  Main Program Loop
# ─────────────────────────────────────────────────
def main():
    print_banner()
    print(f"{GREY}  This tool checks your password's strength based on security{RESET}")
    print(f"{GREY}  policies: length, character variety, and known breach lists.{RESET}\n")

    while True:
        print(f"{CYAN}  Options:{RESET}")
        print(f"    {WHITE}[1]{RESET} Check a password")
        print(f"    {WHITE}[2]{RESET} Check multiple passwords from a file")
        print(f"    {WHITE}[q]{RESET} Quit\n")

        choice = input(f"{BOLD}  Enter choice: {RESET}").strip().lower()

        if choice == "q":
            print(f"\n{CYAN}  Stay secure. — DecodeLabs 🔐{RESET}\n")
            break

        elif choice == "1":
            # Hide input using getpass for security (no echo to terminal)
            import getpass
            password = getpass.getpass(
                prompt=f"\n{BOLD}  Enter password to check (hidden): {RESET}"
            )
            if not password:
                print(f"\n{RED}  ⚠  No password entered.{RESET}\n")
                continue
            result = check_password_strength(password)
            print_report(result, password)

        elif choice == "2":
            filepath = input(f"\n{BOLD}  Enter path to text file (one password per line): {RESET}").strip()
            try:
                with open(filepath, "r") as f:
                    passwords = [line.strip() for line in f if line.strip()]
                print(f"\n{CYAN}  Scanning {len(passwords)} password(s)...{RESET}")
                summary = {"Weak": 0, "Medium": 0, "Strong": 0}
                for pw in passwords:
                    result = check_password_strength(pw)
                    summary[result["level"]] += 1
                    color = result["color_code"]
                    masked = pw[:2] + "*" * (len(pw) - 2)
                    print(f"  {masked:30s} → {color}{BOLD}{result['level']}{RESET} (Score: {result['score']}/5)")
                print(f"\n{BOLD}  Summary:{RESET}")
                print(f"    {GREEN}Strong : {summary['Strong']}{RESET}")
                print(f"    {YELLOW}Medium : {summary['Medium']}{RESET}")
                print(f"    {RED}Weak   : {summary['Weak']}{RESET}\n")
            except FileNotFoundError:
                print(f"\n{RED}  ⚠  File not found: {filepath}{RESET}\n")

        else:
            print(f"\n{RED}  ⚠  Invalid choice. Enter 1, 2, or q.{RESET}\n")


if __name__ == "__main__":
    main()
