import re
import string
import hmac

# ─────────────────────────────────────────────────
#  Common / leaked passwords blacklist (basic set)
# ─────────────────────────────────────────────────
COMMON_PASSWORDS = {
    "password", "123456", "password123", "admin", "letmein",
    "qwerty", "abc123", "iloveyou", "111111", "welcome",
    "monkey", "dragon", "master", "hello", "sunshine",
    "shadow", "princess", "football", "pass", "test",
    "123456789", "12345678", "1234567", "12345", "1234",
    "password1", "password12", "123123", "654321", "superman",
    "batman", "trustno1", "starwars", "passw0rd", "admin123"
}


def check_password_strength(password: str) -> dict:
    """
    Analyse password and return a detailed strength report.

    Returns a dict with:
        score       : int  (0-5)
        level       : str  ('Weak' | 'Medium' | 'Strong')
        color_code  : str  (ANSI color)
        issues      : list of strings describing what's missing
        tips        : list of improvement tips
        criteria    : dict of individual boolean checks
    """
    issues = []
    tips   = []

    # ── Individual Criteria ──────────────────────────────────
    has_min_length    = len(password) >= 8
    has_good_length   = len(password) >= 12
    has_uppercase     = any(c.isupper() for c in password)
    has_lowercase     = any(c.islower() for c in password)
    has_digit         = any(c.isdigit() for c in password)
    has_symbol        = any(c in string.punctuation for c in password)
    not_common        = password.lower() not in COMMON_PASSWORDS
    no_repeat_pattern = not bool(re.search(r'(.)\1{2,}', password))   # no "aaa" etc.

    criteria = {
        "Minimum length (8+)"   : has_min_length,
        "Good length (12+)"     : has_good_length,
        "Uppercase letter"      : has_uppercase,
        "Lowercase letter"      : has_lowercase,
        "Number (0-9)"          : has_digit,
        "Special symbol"        : has_symbol,
        "Not a common password" : not_common,
        "No repeated chars"     : no_repeat_pattern,
    }

    # ── Collect Issues & Tips ────────────────────────────────
    if not has_min_length:
        issues.append("Too short (minimum 8 characters required)")
        tips.append("Add more characters — aim for 12+")

    if not has_uppercase:
        issues.append("No uppercase letters found")
        tips.append("Mix in at least one uppercase letter (A-Z)")

    if not has_lowercase:
        issues.append("No lowercase letters found")
        tips.append("Include lowercase letters (a-z)")

    if not has_digit:
        issues.append("No numbers found")
        tips.append("Add at least one number (0-9)")

    if not has_symbol:
        issues.append("No special characters found")
        tips.append("Use symbols like @, #, $, !, %, &")

    if not not_common:
        issues.append("This is a commonly leaked password!")
        tips.append("Choose a unique passphrase or random string")

    if not no_repeat_pattern:
        issues.append("Repeated characters detected (e.g., 'aaa')")
        tips.append("Avoid repeating the same character 3+ times in a row")

    if not has_good_length and has_min_length:
        tips.append("Increase to 12+ characters for extra protection")

    # ── Scoring (0-5) ────────────────────────────────────────
    score = sum([
        has_min_length,
        has_uppercase,
        has_lowercase,
        has_digit,
        has_symbol,
    ])

    # Bonuses / penalties
    if has_good_length:
        score = min(score + 1, 5)
    if not not_common:
        score = max(score - 2, 0)
    if not no_repeat_pattern:
        score = max(score - 1, 0)

    # ── Strength Level ───────────────────────────────────────
    if score <= 1:
        level      = "Weak"
        color_code = "\033[91m"   # red
        bar_fill   = 1
    elif score <= 3:
        level      = "Medium"
        color_code = "\033[93m"   # yellow
        bar_fill   = 3
    else:
        level      = "Strong"
        color_code = "\033[92m"   # green
        bar_fill   = 5

    return {
        "score"      : score,
        "level"      : level,
        "color_code" : color_code,
        "bar_fill"   : bar_fill,
        "issues"     : issues,
        "tips"       : tips,
        "criteria"   : criteria,
        "length"     : len(password),
    }


